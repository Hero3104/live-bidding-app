# Copy this file to .env (same folder as docker-compose.yml) and fill in real values.
# .env is already excluded via .gitignore — never commit real secrets.

POSTGRES_USER=bidding_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=bidding_db

# Generate a strong random value, e.g.: openssl rand -base64 48
JWT_SECRET=change_this_to_a_long_random_string
